#!/bin/bash
# Secrets managed by chezmoi — 3-tier fallback pattern:
#   1. 1Password (op CLI available) → pulls secret directly
#   2. promptStringOnce (no op) → asks once, stores in chezmoi.toml
#   3. REPLACE_ME (user skipped prompt) → placeholder to fill later

# Example: 3-tier secret pattern
# 1. Add to .chezmoi.toml.tmpl (op branch + else/prompt branch):
#   op:     myApiKey = {{ `{{ onepasswordRead "op://Personal/MyAPI/credential" | quote }}` }}
#   else:   myApiKey = {{ `{{ promptStringOnce . "myApiKey" "My API key (Enter to skip)" | quote }}` }}
#
# 2. Use the data variable here (no op/else branching needed):
# export MY_API_KEY={{ `{{ if .myApiKey }}{{ .myApiKey }}{{ else }}REPLACE_ME{{ end }}` }}

# Secrets are resolved once during `chezmoi init`, not on every `chezmoi apply`.
# To refresh: re-run `chezmoi init`.
# Data keys must be unique camelCase across all templates.
