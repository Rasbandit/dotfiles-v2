{
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Git",
      "Dotnet",
      "Npm",
      "Npx",
      "Node",
      "Pnpm",
      "Yarn",
      "Cargo",
      "Python",
      "Pip",
      "Pipx",
      "Bash",
      "Sh",
      "Powershell",
      "Pwsh"
    ],
    "allowMCPServers": [
      "git",
      "memory",
      "sequential-thinking",
      "filesystem",
      "chrome-devtools",
      "obsidian",
      "engram"
    ]
  },
  "model": "opus",
  "skipDangerousModePermissionPrompt": true,
  "bypassPermissionsAllowed": true
}
