#!/bin/bash

decompress_all() {
    DIRECTORY=${1:-'.'}

    for file in "$DIRECTORY"/*; do
        case "$file" in
            *.zip)
                echo "Decompressing $file..."
                unzip -o "$file" -d "${file%.*}"
                ;;
            *.7z)
                echo "Decompressing $file..."
                7z x "$file" -o"${file%.*}"
                ;;
            *.tar)
                echo "Decompressing $file..."
                mkdir -p "${file%.*}" && tar -xf "$file" -C "${file%.*}"
                ;;
            *.tar.gz | *.tgz)
                echo "Decompressing $file..."
                mkdir -p "${file%.*}" && tar -xzf "$file" -C "${file%.*}"
                ;;
            *.tar.bz2 | *.tbz2)
                echo "Decompressing $file..."
                mkdir -p "${file%.*}" && tar -xjf "$file" -C "${file%.*}"
                ;;
            *.rar)
                echo "Decompressing $file..."
                mkdir -p "${file%.*}" && unrar x "$file" "${file%.*}/"
                ;;
            *)
                echo "Skipping $file: unsupported file type."
                ;;
        esac
    done
}

_dots_sync_watched() {
  local watched="$(chezmoi source-path)/.watched-paths"
  [ -f "$watched" ] || return 0

  # Phase 1: Add new/changed files
  while IFS= read -r path || [ -n "$path" ]; do
    local expanded="${path/#\~/$HOME}"
    if [ -e "$expanded" ]; then
      chezmoi add --force "$expanded" 2>/dev/null || true
    fi
  done < "$watched"
  chezmoi re-add

  # Phase 2: Detect files removed from filesystem but still in chezmoi
  local managed
  managed=$(chezmoi managed 2>/dev/null)
  local orphans=()

  while IFS= read -r path || [ -n "$path" ]; do
    local expanded="${path/#\~/$HOME}"
    local rel="${expanded/#$HOME\//}"
    while IFS= read -r managed_file; do
      [ -n "$managed_file" ] || continue
      if [[ "$managed_file" == "$rel"/* || "$managed_file" == "$rel" ]] && [ ! -e "$HOME/$managed_file" ]; then
        orphans+=("$managed_file")
      fi
    done <<< "$managed"
  done < "$watched"

  [ ${#orphans[@]} -eq 0 ] && return 0

  if [ -t 0 ]; then
    echo "Files removed from filesystem but still tracked by chezmoi:"
    for file in "${orphans[@]}"; do
      read -rp "  Remove '$file' from chezmoi? (y/N) " ans
      if [[ "$ans" =~ ^[Yy]$ ]]; then
        chezmoi forget --force "$HOME/$file" 2>/dev/null
        echo "    Removed."
      else
        echo "    Kept."
      fi
    done
  else
    local list
    list=$(printf '  %s\n' "${orphans[@]}")
    notify-send "Dotfiles: orphaned files detected" "Files deleted but still tracked:\n$list\nRun 'dots_add' to review." 2>/dev/null || true
  fi
}

dots_track_folder() {
  local target="${1:-$(pwd)}"
  target="${target%/}"
  local watched="$(chezmoi source-path)/.watched-paths"

  # Resolve ~ for comparison
  local expanded="${target/#\~/$HOME}"
  expanded="$(realpath "$expanded" 2>/dev/null || echo "$expanded")"

  # Normalize to ~/ form for storage
  local stored="${expanded/#$HOME/\~}"

  # Check if already tracked
  if [ -f "$watched" ] && grep -qxF "$stored" "$watched"; then
    echo "Already watching: $stored"
  else
    echo "$stored" >> "$watched"
    echo "Now watching: $stored"
  fi

  # Show untracked files and add them
  local managed
  managed=$(chezmoi managed 2>/dev/null)
  local has_untracked=false

  while IFS= read -r -d '' file; do
    local rel="${file/#$HOME\//}"
    if ! echo "$managed" | grep -qxF "$rel"; then
      has_untracked=true
      echo "  Adding: $rel"
    fi
  done < <(find "$expanded" -type f -print0 2>/dev/null)

  chezmoi add --force "$expanded" 2>/dev/null || true

  if ! $has_untracked; then
    echo "  All files already tracked."
  fi
}

dots_add() {
  if [ $# -eq 0 ]; then
    _dots_sync_watched
  else
    chezmoi add "$@"
  fi
}

_dots_cleanup_removed() {
  local before="$1"
  local after
  after=$(chezmoi managed 2>/dev/null | sort)
  local removed
  removed=$(comm -23 <(echo "$before") <(echo "$after"))
  [ -n "$removed" ] || return 0
  while IFS= read -r file; do
    [ -n "$file" ] || continue
    if [ -e "$HOME/$file" ]; then
      rm -f "$HOME/$file"
      echo "Cleaned up removed file: $file"
    fi
  done <<< "$removed"
}

dots_remove() {
  if [ $# -eq 0 ]; then
    echo "Usage: dots_remove <file>..."
    return 1
  fi
  for file in "$@"; do
    local target
    target="$(realpath "$file" 2>/dev/null || echo "$file")"
    chezmoi forget --force "$target" 2>/dev/null
    if [ -e "$target" ]; then
      rm -f "$target"
      echo "Deleted: $target"
    fi
  done
}

dots_push() {
  _dots_sync_watched && \
  cd "$(chezmoi source-path)" && \
  git add -A && \
  git commit -m "update: $(date '+%Y-%m-%d %H:%M')" && \
  git push && \
  cd - > /dev/null
}

dots_pull() {
  local before
  before=$(chezmoi managed 2>/dev/null | sort)
  cd "$(chezmoi source-path)" && \
  git pull && \
  cd - > /dev/null
  _dots_cleanup_removed "$before"
  chezmoi apply
  _dots_sync_watched
}
