#!/bin/bash

decompress_all() {
    DIRECTORY=${1:-'.'}

    for file in "$DIRECTORY"/*; do
        case "$file" in
            *.zip)
                echo "Decompressing $file..."
                unzip -o "$file" -d "${file%.*}"
                ;;
            *.7z)
                echo "Decompressing $file..."
                7z x "$file" -o"${file%.*}"
                ;;
            *.tar)
                echo "Decompressing $file..."
                mkdir -p "${file%.*}" && tar -xf "$file" -C "${file%.*}"
                ;;
            *.tar.gz | *.tgz)
                echo "Decompressing $file..."
                mkdir -p "${file%.*}" && tar -xzf "$file" -C "${file%.*}"
                ;;
            *.tar.bz2 | *.tbz2)
                echo "Decompressing $file..."
                mkdir -p "${file%.*}" && tar -xjf "$file" -C "${file%.*}"
                ;;
            *.rar)
                echo "Decompressing $file..."
                mkdir -p "${file%.*}" && unrar x "$file" "${file%.*}/"
                ;;
            *)
                echo "Skipping $file: unsupported file type."
                ;;
        esac
    done
}

dots_add() {
  if [ $# -eq 0 ]; then
    chezmoi re-add
  else
    chezmoi add "$@"
  fi
}

dots_remove() {
  if [ $# -eq 0 ]; then
    echo "Usage: dots_remove <file>..."
    return 1
  fi
  chezmoi forget "$@"
}

dots_push() {
  chezmoi re-add && \
  cd "$(chezmoi source-path)" && \
  git add -A && \
  git commit -m "update: $(date '+%Y-%m-%d %H:%M')" && \
  git push && \
  cd - > /dev/null
}

dots_pull() {
  cd "$(chezmoi source-path)" && \
  git pull && \
  cd - > /dev/null && \
  chezmoi apply
}
